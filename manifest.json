{
  "manifest_version": 3,
  "name": "YouTube Shorts & Playables Remover",
  "version": "1.2.1",
  "description": "Removes Shorts and Playables from YouTube homepage, search results, and sidebar.",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Shorts & Playables Remover",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
